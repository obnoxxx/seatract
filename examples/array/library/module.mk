LIBARRAY_BASE_DIR := $(call GET_SELF_DIR)
LIBARRAY_LIB_DIR := $(LIBARRAY_BASE_DIR)/lib
LIBARRAY_INC_DIR := $(LIBARRAY_BASE_DIR)/include
LIBARRAY_SRC_DIR := $(LIBARRAY_BASE_DIR)/src
LIBARRAY_OBJ_DIR := $(LIBARRAY_BASE_DIR)/obj
LIBARRAY_LIB_A := $(LIBARRAY_LIB_DIR)/libarray.a
LIBARRAY_HDR := $(LIBARRAY_INC_DIR)/array.h
LIBARRAY_PC_DIR := $(LIBARRAY_LIB_DIR)/pkgconfig
LIBARRAY_PC     := $(LIBARRAY_PC_DIR)/libarray.pc


LIBARRAY_SRCS := $(wildcard $(LIBARRAY_SRC_DIR)/*.c)
LIBARRAY_OBJS := $(patsubst $(LIBARRAY_SRC_DIR)/%.c, $(LIBARRAY_OBJ_DIR)/%.o, $(LIBARRAY_SRCS))
LIBARRAY_OBJ := $(LIBARRAY_OBJ_DIR)/array.o

# 1. Set cflags for these objects
$(LIBARRAY_OBJS): CFLAGS += $(CFLAGS_USE_SEATRACT) -I$(LIBARRAY_INC_DIR)

# cflags/cppflags, ldflags, and ldlibs for using this library:
LDLIBS_USE_LIBARRAY := -larray
LDFLAGS_USE_LIBARRAY := -L$(LIBARRAY_LIB_DIR)
CPPFLAGS_USE_LIBARRAY := -I$(LIBARRAY_INC_DIR)
CFLAGS_USE_LIBARRAY := $(CPPFLAGS_USE_LIBARRAY)



# 2. Define the build rule
$(LIBARRAY_OBJ_DIR)/%.o: $(LIBARRAY_SRC_DIR)/%.c $(SEATRACT_H) $(LIBARRAY_HDR) $(LIBARRAY_OBJ_DIR)
	$(CC) $(CFLAGS) $(GLOBAL_CFLAGS) -c $< -o $@

$(LIBARRAY_OBJ_DIR):
	@mkdir -p $(LIBARRAY_OBJ_DIR)

$(LIBARRAY_LIB_DIR):
	@mkdir -p $(LIBARRAY_LIB_DIR)

$(LIBARRAY_PC_DIR):
	@mkdir -p $(LIBARRAY_PC_DIR)

$(LIBARRAY_PC): $(LIBARRAY_BASE_DIR)/libarray.pc.in | $(LIBARRAY_PC_DIR)
	sed -e 's|@LIBDIR@|$(LIBARRAY_LIB_DIR)|g' \
	    -e 's|@INCLUDEDIR@|$(LIBARRAY_INC_DIR)|g' \
	    $< > $@

.PHONY: libarray
libarray: $(LIBARRAY_LIB_A)

.PHONY: array.library
array.library: libarray


$(LIBARRAY_LIB_A): $(LIBARRAY_OBJS) $(LIBARRAY_LIB_DIR)
	@$(AR) -rc $@ $(LIBARRAY_OBJS)

# 3. POPULATE THE GLOBALS
ALL_TARGETS += $(LIBARRAY_LIB_A) $(LIBARRAY_PC)
CLEAN_LIST  += $(LIBARRAY_OBJS) $(LIBARRAY_LIB_A) $(LIBARRAY_OBJ_DIR) $(LIBARRAY_PC) $(LIBARRAY_PC_DIR) $(LIBARRAY_LIB_DIR)
