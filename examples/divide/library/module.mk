LIBDIVIDE_BASE_DIR := $(call GET_SELF_DIR)
LIBDIVIDE_LIB_DIR := $(LIBDIVIDE_BASE_DIR)/lib
LIBDIVIDE_INC_DIR := $(LIBDIVIDE_BASE_DIR)/include
LIBDIVIDE_SRC_DIR := $(LIBDIVIDE_BASE_DIR)/src
LIBDIVIDE_OBJ_DIR := $(LIBDIVIDE_BASE_DIR)/obj
LIBDIVIDE_LIB_A := $(LIBDIVIDE_LIB_DIR)/libdivide.a
LIBDIVIDE_HDR := $(LIBDIVIDE_INC_DIR)/divide.h
LIBDIVIDE_PC_DIR := $(LIBDIVIDE_LIB_DIR)/pkgconfig
LIBDIVIDE_PC     := $(LIBDIVIDE_PC_DIR)/libdivide.pc


LIBDIVIDE_SRCS := $(wildcard $(LIBDIVIDE_SRC_DIR)/*.c)
LIBDIVIDE_OBJS := $(patsubst $(LIBDIVIDE_SRC_DIR)/%.c, $(LIBDIVIDE_OBJ_DIR)/%.o, $(LIBDIVIDE_SRCS))
LIBDIVIDE_OBJ := $(LIBDIVIDE_OBJ_DIR)/divide.o

# 1. Set cflags for these objects
$(LIBDIVIDE_OBJS): CFLAGS += $(CFLAGS_USE_SEATRACT) -I$(LIBDIVIDE_INC_DIR)

# cflags and ldflags for using this library:
LDLIBS_USE_LIBDIVIDE := -ldivide
LDFLAGS_USE_LIBDIVIDE := -L$(LIBDIVIDE_LIB_DIR)
CFLAGS_USE_LIBDIVIDE := -I$(LIBDIVIDE_INC_DIR)



# 2. Define the build rule
$(LIBDIVIDE_OBJ_DIR)/%.o: $(LIBDIVIDE_SRC_DIR)/%.c $(SEATRACT_H) $(LIBDIVIDE_HDR) $(LIBDIVIDE_OBJ_DIR)
	$(CC) $(CFLAGS) $(GLOBAL_CFLAGS) -c $< -o $@

$(LIBDIVIDE_OBJ_DIR):
	@mkdir -p $(LIBDIVIDE_OBJ_DIR)

$(LIBDIVIDE_LIB_DIR):
	@mkdir -p $(LIBDIVIDE_LIB_DIR)

$(LIBDIVIDE_PC_DIR):
	@mkdir -p $(LIBDIVIDE_PC_DIR)

$(LIBDIVIDE_PC): $(LIBDIVIDE_BASE_DIR)/libdivide.pc.in | $(LIBDIVIDE_PC_DIR)
	sed -e 's|@LIBDIR@|$(LIBDIVIDE_LIB_DIR)|g' \
	    -e 's|@INCLUDEDIR@|$(LIBDIVIDE_INC_DIR)|g' \
	    $< > $@

.PHONY: libdivide
libdivide: $(LIBDIVIDE_LIB_A)

.PHONY: divide.library
divide.library: libdivide


$(LIBDIVIDE_LIB_A): $(LIBDIVIDE_OBJS) $(LIBDIVIDE_LIB_DIR)
#	$(AR) -rc $@ $^
	@$(AR) -rc $@ $(LIBDIVIDE_OBJS)

# 3. POPULATE THE GLOBALS
ALL_TARGETS += $(LIBDIVIDE_LIB_A) $(LIBDIVIDE_PC)
CLEAN_LIST  += $(LIBDIVIDE_OBJS) $(LIBDIVIDE_LIB_A) $(LIBDIVIDE_OBJ_DIR) $(LIBDIVIDE_PC) $(LIBDIVIDE_PC_DIR) $(LIBDIVIDE_LIB_DIR)
